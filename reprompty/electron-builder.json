{
  "appId": "com.reprompty.app",
  "productName": "Reprompty",
  "directories": {
    "output": "release9"
  },
  "files": [
    "dist/**/*",
    "package.json"
  ],
  "extraMetadata": {
    "main": "dist/main/index.js"
  },
  "extraResources": [
    {
      "from": "build",
      "to": ".",
      "filter": ["**/*"]
    }
  ],
  "asar": false,
  "win": {
    "target": [
      {
        "target": "dir",
        "arch": ["x64"]
      }
    ]
  }
}
